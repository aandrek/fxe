{
  "name": "@aandrek/fxe",
  "version": "0.4.12",
  "description": "A library to call functions in sync with a beat",
  "main": "dist/fxengine.bundle.js",
  "types": "fxengine.d.ts",
  "scripts": {
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "build": "webpack --config webpack.prod.js",
    "watch": "webpack --config webpack.dev.js --watch",
    "b": "webpack --config webpack.dev.js",
    "lint": "eslint src/**/*.ts",
    "lint:fix": "eslint src/**/*.ts --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\"",
    "type-check": "tsc --noEmit",
    "validate": "npm run type-check && npm run lint && npm run test",
    "prepare": "husky || true"
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix",
      "prettier --write",
      "jest --bail --findRelatedTests"
    ]
  },
  "author": "aandrek",
  "license": "ISC",
  "devDependencies": {
    "@types/jest": "^30.0.0",
    "@types/three": "^0.185.0",
    "@typescript-eslint/eslint-plugin": "^8.62.0",
    "@typescript-eslint/parser": "^8.62.0",
    "eslint": "^10.5.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.4",
    "terser-webpack-plugin": "^5.6.1",
    "ts-jest": "^29.4.11",
    "ts-loader": "^9.5.1",
    "typescript": "^5.4.5",
    "webpack": "^5.72.0",
    "webpack-cli": "^4.9.2",
    "webpack-merge": "^6.0.1"
  },
  "dependencies": {
    "three": ">=0.139.0"
  },
  "peerDependencies": {
    "three": ">=0.139.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/aandrek/fxe.git"
  },
  "bugs": {
    "url": "https://github.com/aandrek/fxe/issues"
  },
  "homepage": "https://github.com/aandrek/fxe#readme"
}
